## CLOCK
set_property PACKAGE_PIN E3 [get_ports {clk}]
set_property IOSTANDARD LVCMOS33 [get_ports {clk}]
create_clock -period 10.0 [get_ports {clk}]

## RESET
set_property PACKAGE_PIN D9 [get_ports {rst}]
set_property IOSTANDARD LVCMOS33 [get_ports {rst}]

## JA PMOD (MATCHING YOUR TOP SIGNAL NAMES)

set_property PACKAGE_PIN G13 [get_ports {AG}]
set_property PACKAGE_PIN B11 [get_ports {AY}]
set_property PACKAGE_PIN A11 [get_ports {AR}]
set_property PACKAGE_PIN D12 [get_ports {BG}]
set_property PACKAGE_PIN D13 [get_ports {BY}]
set_property PACKAGE_PIN B18 [get_ports {BR}]

set_property IOSTANDARD LVCMOS33 [get_ports {AG AY AR BG BY BR}]
